{
  "name": "@webpage/frontend",
  "author": "Sean McBroom (sean.mcbroom@outlook.com)",
  "version": "1.0.0",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    ".": "./src/main.ts"
  },
  "scripts": {
    "analyze:bundle": "vite build --mode analyze:bundle",
    "analyze:cycles": "vite build --mode analyze:cycles",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:inspect": "eslint-config-inspector",
    "build": "vite build && tsx scripts/generateSitemap.ts && tsx scripts/staticImages.ts",
    "check": "npm run lint && npm run check:types",
    "check:types": "vue-tsc",
    "start": "vite",
    "serve": "vite preview",
    "dev": "npm run start",
    "prod": "npm run build && npm run serve",
    "clean": "git clean -fxd"
  },
  "dependencies": {
    "@intlify/unplugin-vue-i18n": "11.2.4",
    "@tailwindcss/vite": "4.3.1",
    "@vueuse/core": "14.3.0",
    "axios": "1.18.1",
    "defu": "6.1.7",
    "markdown-it": "14.2.0",
    "vue": "3.5.38",
    "vue-i18n": "11.4.5",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@tailwindcss/typography": "0.5.20",
    "@tsconfig/node20": "20.1.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitejs/plugin-vue-jsx": "5.1.6",
    "@vue/eslint-config-typescript": "14.9.0",
    "@vue/tsconfig": "0.9.1",
    "autoprefixer": "10.5.0",
    "file-loader": "6.2.0",
    "globals": "17.7.0",
    "npm-run-all2": "9.0.1",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.1",
    "unplugin-vue-components": "32.1.0",
    "url-loader": "4.1.1",
    "vite": "8.1.0",
    "vite-imagetools": "^10.0.0",
    "vite-plugin-vue-devtools": "8.1.5",
    "vue-eslint-parser": "^10.4.1"
  }
}
