{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "nodenext",
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"],
      "@/test/*": ["./test/*"]
    },
    "types": ["node"],
    "lib": ["es2023"],
    "composite": true
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules"]
}